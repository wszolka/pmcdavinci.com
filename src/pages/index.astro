---
import BaseLayout from "@layouts/BaseLayout.astro";
import globalSettings from '@config/config.json.ts';
import { getEntry } from "astro:content";
import BackgroundMediaPostHeader from "@components/BackgroundMediaPostHeader.astro";
import ConstSlider from "@components/ConstSlider.astro";
import { Image } from "astro:assets";
import "@styles/post.css";
import "@styles/post-content.css";
import sideImage from "@assets/images/kas.jpg";

const header_post = await getEntry("blog", "header");

const t = await import(/* @vite-ignore */ `@locales/${globalSettings.language}.json`)
  .catch(() => import(/* @vite-ignore */ '@locales/en.json'));
---

<BaseLayout globalSettings={globalSettings} t={t}>
  <main>  
    <BackgroundMediaPostHeader globalSettings={globalSettings} t={t} post={header_post} hide_post_links={true} content_length="Full Width"/>

    <article class="article" data-is-post="true" data-has-header="false">
      <div class="post-content narrow-container">
        <div class="post-content-inner-wrapper">
          <div class="post-content-inner" style="border-bottom: none;">
            <br/>
            <br/>

            <blockquote class="blockquote-alt">
              Innovation is valuable only when it is applied.<br/>
              Creativity is not a talent of a few - it is a capability that can be developed in everyone.
            </blockquote>

            <br/>
            <br/>
            <br/>
            <br/>

            <blockquote>
              Organizations rarely lack ideas
              They lack environments where ideas can survive reality.
            </blockquote>

            <br/>
            <br/>
            <br/>
            <br/>

            <blockquote class="blockquote-alt">
              Organizations naturally optimize around what they already know.
              Innovation often begins when new perspectives enter the system.
            </blockquote>

            <br/>
            <br/>

          </div>
        </div>
        </div>
      </div>

      <div class="post-content  wide-container">
        <div class="post-content-inner-wrapper">
          <div class="post-content-inner" style="border-bottom: none;">

            <ConstSlider
              image={sideImage}
              imageAlt="Innovation"
              titles={[
                "APPLIED INNOVATION",
                "CREATIVITY AS CAPABILITY",
                "INNOVATION LEADERSHIP",
              ]}
              description="I bring international innovation practice into organizations and translate it into applied innovation - strengthening how they operate, adapt, and grow. My perspective comes from leading and implementing innovation from within organizations - staying close to operational reality rather than observing it from outside. An external innovation director bringing global perspective into operational systems."
            />
          </div>
        </div>
      </div>

      <div class="post-content narrow-container">
        <div class="post-content-inner-wrapper">
          <div class="post-content-inner" style="border-bottom: none;">
            <h2>How I work with organizations?</h2>
            <p>
              I work alongside leadership teams and operational structures to help organizations:
              <ul>
              <li>make innovation executable within existing systems,</li>
              <li>connect strategy with everyday decision-making,</li>
              <li>enable teams to operate differently without disrupting performance,</li>
              <li>move from experimentation to implementation.</li>
              </ul>
              Sometimes this means designing programmes.
              Sometimes leading transformation initiatives.
              Sometimes stepping into interim leadership roles.
              <br/><br/>
              <h4>Always — working close to operational reality and pragmatism.</h4>
            </p>
            <br/>
            <br/>
            <br/>
            <br/>
            <a name="international-work"></a>
            <h2>International Work</h2>
            <p>
              <strong>Working Across Systems</strong><br/>
              <p>My work is shaped by international programmes, cross-sector collaboration, and engagement with innovation ecosystems connecting business, academia, and emerging ventures.</p>
              <p>Exposure to different organizational models allows translation between worlds that rarely meet directly - corporate structures, research environments, entrepreneurial ecosystems, and new business models.</p>
              <p>Global perspective becomes valuable only when translated into operational reality.</p>
              <p>Organizations gain broader benchmarks and alternative ways of operating without losing stability.</p>
            </p>
            <br/>
            <br/>
            <a name="why-work-together"></a>
            <h2>Why Work Together</h2>
            <p>Organizations typically engage when:
              <ul>
                <li>innovation exists in strategy but not in everyday execution,</li>
                <li>growth requires new ways of operating,</li>
                <li>leadership seeks external perspective grounded in real practice,</li>
                <li>organizations want to evolve without losing operational stability.</li>
              </ul>
            </p> 

          </div>        
        </div>
      </div>
    </article>


  </main>
</BaseLayout>

